@model FlightManagementSystem.Application.Flights.DTO.Requests.CreateFlightRequest

<h2>Add Flight</h2>

<style>
    .form-group {
        margin-bottom: 15px;
    }

    label {
        display: block;
        font-weight: 600;
        margin-bottom: 5px;
    }

    select {
        width: 300px;
        padding: 6px;
    }

    .error {
        color: red;
        font-size: 12px;
    }

    button {
        margin-top: 10px;
        padding: 8px 14px;
        cursor: pointer;
    }
</style>

<form asp-action="Create" method="post">

    <div class="form-group">
        <label asp-for="DepartureAirportId">Departure Airport</label>
        <select asp-for="DepartureAirportId"
                asp-items="ViewBag.Airports ?? new List<SelectListItem>()">
        </select>
        <span asp-validation-for="DepartureAirportId" class="error"></span>
    </div>

    <div class="form-group">
        <label asp-for="DestinationAirportId">Destination Airport</label>
        <select asp-for="DestinationAirportId"
                asp-items="ViewBag.Airports ?? new List<SelectListItem>()">
        </select>
        <span asp-validation-for="DestinationAirportId" class="error"></span>
    </div>

    <div class="form-group">
        <label asp-for="AircraftId">Aircraft Model</label>
        <select asp-for="AircraftId"
                asp-items="ViewBag.Aircraft ?? new List<SelectListItem>()">
        </select>
        <span asp-validation-for="AircraftId" class="error"></span>
    </div>

    <button type="submit">Add Flight</button>

</form>