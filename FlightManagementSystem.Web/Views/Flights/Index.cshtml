@model List<FlightManagementSystem.Application.Flights.DTO.Responses.FlightResponse>

<h2>Flights</h2>

<a href="/Flights/Create">Create Flight</a>

<style>
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    th, td {
        padding: 12px 16px;
        text-align: left;
        border-bottom: 1px solid #ddd;
    }

    th {
        background-color: #f5f5f5;
        font-weight: bold;
    }

    tr:hover {
        background-color: #f9f9f9;
    }

    a {
        text-decoration: none;
        color: #007bff;
    }

    a:hover {
        text-decoration: underline;
    }
</style>

<table>
    <tr>
        <th>From</th>
        <th>To</th>
        <th>Aircraft</th>
        <th>Distance</th>
        <th>Fuel</th>
        <th>Actions</th>
    </tr>

@foreach (var f in Model)
{
    <tr>
        <td>@f.DepartureAirportName - @f.DepartureAirportCode</td>
        <td>@f.DestinationAirportName - @f.DestinationAirportCode</td>
        <td>@f.AircraftModel</td>
        <td>@f.DistanceKm km</td>
        <td>@f.FuelRequired L</td>
        <td>
            <a href="/Flights/Edit/@f.Id">Edit</a>
        </td>
    </tr>
}
</table>